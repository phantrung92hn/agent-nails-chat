# ─────────────────────────────────────────────────────────────────
# Sakura Nails Chat — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED: Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── REQUIRED: Supabase (customer DB + booking history) ────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── REQUIRED: Google Calendar (availability + booking) ────────────
# Option A: Full JSON service account (base64 or raw JSON)
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B: Individual fields (if not using GOOGLE_SERVICE_ACCOUNT)
# GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...

# ── REQUIRED: Calendar IDs for each technician ───────────────────
CALENDAR_LISA=lisa-calendar-id@group.calendar.google.com
CALENDAR_ANNA=anna-calendar-id@group.calendar.google.com
CALENDAR_MAI=mai-calendar-id@group.calendar.google.com
